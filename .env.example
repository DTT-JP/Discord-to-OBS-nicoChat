# ═══════════════════════════════════════════════
# Discord-to-OBS-nicoChat — 環境変数設定ファイル
# ═══════════════════════════════════════════════

# ── Discord 認証情報 ──────────────────────────────
DISCORD_TOKEN=ここにBotトークンを入力
CLIENT_ID=ここにアプリケーションIDを入力
# GUILD_ID=ここにギルドIDを入力  ← 通常不要

# ── Bot製作者設定 ──────────────────────────────────
# /blacklist コマンドを実行できるDiscord ユーザーID
BOT_OWNER_ID=ここにBot製作者のDiscordユーザーIDを入力
# グローバルBLユーザー向けの異議申し立てURL（/my-status で表示）
GLOBAL_BLACKLIST_APPEAL_URL=

# グローバルBLギルド向けの異議申し立てURL（/global_guild_blacklist でDMに表示）
GLOBAL_GUILD_BLACKLIST_APPEAL_URL=

# ── サーバー設定 ──────────────────────────────────
PORT=3000
HOST=localhost

# 本番では NODE_ENV=production を推奨（CORS 強制ルールが有効になります）
# NODE_ENV=production

# Socket.io CORS: ブラウザからアクセスするオーバーレイのオリジン（カンマ区切り・パス不可）
# 本番(NODE_ENV=production)では必須。開発で空のときは localhost 系 Origin のみ追加許可。
# 例: ALLOWED_ORIGINS=https://overlay.example.com
ALLOWED_ORIGINS=

# OBS ブラウザソース等（Origin ヘッダ無し）を許可するか
# 本番では未設定=拒否。OBS を使う本番では ALLOW_NULL_ORIGIN=1 を必ず設定。
# 開発では未設定=許可。拒否したい場合は ALLOW_NULL_ORIGIN=0
# ALLOW_NULL_ORIGIN=1

# 公開URL（HTTPS化する場合のみ設定）
# 未設定の場合は http://HOST:PORT が使われる
# 末尾のスラッシュは不要。https:// で始まると HSTS が有効になります。
PUBLIC_URL=

# リバプロで TLS 終端しているが PUBLIC_URL が http のとき、HSTS を付けたい場合に 1
# ENABLE_HSTS=1

# ── コメント表示設定 ──────────────────────────────
MAX_COMMENTS=30

# ── 認証・暗号化 ──────────────────────────────────
# ギルド設定の暗号化等に使用。64 文字の hex または任意文字列（内部でハッシュ化されます）
MASTER_KEY=ここに32バイト相当の秘密を設定

CODE_EXPIRE_MINUTES=10
# 未設定時は起動ごとにランダム（本番では固定値推奨）
# AUTH_CODE_PEPPER=
