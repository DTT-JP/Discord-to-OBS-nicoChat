# ═══════════════════════════════════════════════
# Discord OBS Overlay — 環境変数設定ファイル
# このファイルを .env にコピーして各値を入力してください
# cp .env.example .env
# ═══════════════════════════════════════════════

# ───────────────────────────────────────────────
# Discord 認証情報
# ───────────────────────────────────────────────

# Botのトークン
# Discord Developer Portal > Bot > Token からコピー
DISCORD_TOKEN=ここにBotトークンを入力

# アプリケーションID
# Discord Developer Portal > General Information > Application ID からコピー
CLIENT_ID=ここにアプリケーションIDを入力

# ギルドID（通常は不要）
# グローバルコマンドへ移行済みのため基本的に設定不要
# 開発時にコマンドを即時反映（ギルドコマンド）したい場合のみ設定する
# GUILD_ID=ここにギルドIDを入力

# ───────────────────────────────────────────────
# サーバー設定
# ───────────────────────────────────────────────

# Expressサーバーが使用するポート番号
PORT=3000

# OBSブラウザソースのURL生成に使用するホスト名
# ローカル運用: localhost のまま
# LAN内の別PCから接続: このPCのローカルIPアドレス（例: 192.168.1.10）
HOST=localhost

# 公開URL（HTTPS化・ポート番号なしにしたい場合に設定）
# リバースプロキシ（nginx等）やトンネル（Cloudflare Tunnel等）経由で
# 外部公開する場合に設定する。設定するとこちらが優先される。
# 末尾のスラッシュは不要。
#
# 設定例（独自ドメイン）  : https://overlay.example.com
# 設定例（サブパス）      : https://example.com/overlay
# 設定例（Cloudflare）    : https://xxxxxxxx.trycloudflare.com
#
# 未設定の場合は http://HOST:PORT が自動的に使われる（ローカル運用向け）
PUBLIC_URL=

# ───────────────────────────────────────────────
# コメント表示設定
# ───────────────────────────────────────────────

# デフォルトの同時表示コメント上限数
# /start コマンドの limit オプションで個別に上書き可能
# /setlimit コマンドで配信中にリアルタイム変更も可能
MAX_COMMENTS=30

# ───────────────────────────────────────────────
# 認証設定
# ───────────────────────────────────────────────

# 認証コード（6桁）の有効期限（分単位）
# OBSでURLを開いてから、この時間内に /auth コマンドで認証を完了してください
# 期限切れの場合は /start からやり直してください
CODE_EXPIRE_MINUTES=10

# ── Bot製作者設定 ──────────────────────────────
# /blacklist コマンドを実行できるユーザーのDiscord ID
# Bot製作者のIDを入力してください
BOT_OWNER_ID=ここにBot製作者のDiscordユーザーIDを入力